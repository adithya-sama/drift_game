PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1547531711}
    m_Modifications:
    - target: {fileID: 243763295041587086, guid: b794de413864f89419c61eade627ddc0,
        type: 3}
      propertyPath: m_text
      value: '''Raik, you were always alive, like everything in this universe. I
        was not the one that offered you life. I didn''t choose you, you chose me.
        I was drawn to you in that forest. You may not know it, but we Morai have
        learnt a lot from you. It is unfortunate that we must part, but we Morai
        must end. I cannot tell you how your journey ends Raik. But you don''t have
        to do this alone, one rarely does. Remember raik, you have been given the
        most precious resource of all. Time. Share it wisely dear friend. Goodbye'''
      objectReference: {fileID: 0}
    - target: {fileID: 243763295041587086, guid: b794de413864f89419c61eade627ddc0,
